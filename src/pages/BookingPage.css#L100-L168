.rental-type-selector {
  display: flex;
  gap: 0.5rem;
  background-color: #EEEEEE;
  padding: 0.4rem;
  border-radius: 4px;
}

.rental-type-selector button {
  flex: 1;
  padding: 0.8rem;
  border: none;
  background: transparent;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  border-radius: 2px;
  transition: all 0.2s ease;
}

.rental-type-selector button.active {
  background-color: #FFF;
  color: #c44848;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.shift-selector {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.shift-box {
  padding: 1.5rem;
  border: 1px solid #E2E2E2;
  border-radius: 4px;
  cursor: pointer;
  text-align: center;
  transition: all 0.3s ease;
}

.shift-box span {
  display: block;
  font-weight: 700;
  margin-bottom: 0.3rem;
}

.shift-box small {
  color: #666;
}

.shift-box.active {
  border-color: #c44848;
  background-color: #fff9f9;
}

.shift-box.active span {
  color: #c44848;
}

/* Schedule display in results */
.res-schedule {
  display: flex;
  justify-content: space-between;
  text-align: left;
  margin-bottom: 2.5rem;
  gap: 2rem;
}

.schedule-item {
  flex: 1;
}

.schedule-item small {
  color: #999;
  letter-spacing: 1px;
  font-weight: 700;
  font-size: 0.7rem;
}

.schedule-item p {
  font-size: 0.95rem;
  font-weight: 600;
  color: #111;
  margin-top: 0.3rem;
}

@media (max-width: 600px) {
  .rental-type-selector {
    flex-direction: column;
  }
  .res-schedule {
    flex-direction: column;
    gap: 1rem;
  }
}
